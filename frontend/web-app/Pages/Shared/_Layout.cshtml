<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Titan Takeaway</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/pages/landing.css" asp-append-version="true" />
</head>
<body>
    <header class="border-bottom bg-white">
        <nav class="navbar navbar-expand-lg navbar-light">
            <div class="container">
                <a class="navbar-brand fw-semibold" asp-area="" asp-page="/Index">Titan-Takeaway</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav" aria-controls="mainNav" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="mainNav">
                    <ul class="navbar-nav ms-auto">
                        <li class="nav-item"><a class="nav-link" href="http://localhost:5000" target="_blank" rel="noreferrer">Ordering API</a></li>
                        <li class="nav-item"><a class="nav-link" href="http://localhost:3000" target="_blank" rel="noreferrer">Grafana</a></li>
                        <li class="nav-item"><a class="nav-link" href="http://localhost:16686" target="_blank" rel="noreferrer">Jaeger</a></li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <main class="container py-4">
        @RenderBody()
    </main>

    <footer class="border-top py-3 text-muted small">
        <div class="container d-flex justify-content-between">
            <span>Titan-Takeaway training shell</span>
            <span id="lastUpdated">Status not yet checked</span>
        </div>
    </footer>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="~/js/pages/landing.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
