{
  "mcpServers": {
    "docker": {
      "command": "docker",
      "args": [
        "mcp",
        "gateway",
        "run"
      ]
    },
    "EXAMPLE-github": {
      "command": "npx",
      "args": [
        "-y",
        "@anthropic/github-mcp-server"
      ],
      "env": {
        "GITHUB_TOKEN": "${GITHUB_TOKEN}"
      }
    }
  }
}
